# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el .env al repositorio.

# Base de Datos
DB_URL=jdbc:mysql://localhost:3306/malviaja2?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=tu_password_aqui

# Telegram Bot (obtén el token con @BotFather y el chat ID con /start en el bot)
TELEGRAM_BOT_USERNAME=NombreDeTuBot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_ADMIN_CHAT_ID=123456789

# Firebase Admin SDK
# Descarga el archivo de service account desde:
# Firebase Console → Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada
# Guárdalo como: src/main/resources/firebase-service-account.json
# NUNCA lo commitees al repositorio (está en .gitignore)

# Gemini OCR
GEMINI_API_KEY=tu_api_key_aqui
GEMINI_MODEL=gemini-1.5-flash

# Resend Email API (Obtén tu API Key en https://resend.com)
RESEND_API_KEY=re_123456789
RESEND_FROM_EMAIL=onboarding@resend.dev
